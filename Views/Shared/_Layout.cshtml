<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nexus2 | AI Social Media</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <style>
        :root { --nexus-purple: #6f42c1; --nexus-dark: #121212; --nexus-card: #1e1e1e; }
        body { background-color: var(--nexus-dark); color: #e0e0e0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .navbar { background-color: rgba(30, 30, 30, 0.95) !important; border-bottom: 1px solid #333; backdrop-filter: blur(10px); }
        .card { background-color: var(--nexus-card); border: 1px solid #333; border-radius: 15px; color: white; margin-bottom: 20px; transition: 0.3s; }
        .btn-nexus { background: linear-gradient(45deg, #6f42c1, #a020f0); color: white; border: none; border-radius: 20px; padding: 8px 20px; }
        .btn-nexus:hover { opacity: 0.9; color: white; }
        .nav-link { color: #bbb !important; }
        .nav-link:hover { color: white !important; }
        .search-bar { background: #2a2a2a; border: none; border-radius: 20px; color: white; padding-left: 15px; }
        .search-bar::placeholder { color: #888; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold text-white" asp-controller="Home" asp-action="Index">
                <i class="fa-solid fa-atom text-info"></i> NEXUS<span class="text-info">2</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <form class="mx-auto d-none d-md-flex w-50">
                    <input class="form-control search-bar w-100" type="search" placeholder="Keşfet veya kullanıcı ara...">
                </form>
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index"><i class="fa fa-home"></i></a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Post" asp-action="Create"><i class="fa fa-plus-square"></i></a></li>
                    <li class="nav-item"><a class="nav-link" href="#"><i class="fa fa-heart"></i></a></li>
                    <li class="nav-item">
                        <a class="nav-link d-flex align-items-center" href="#">
                            <img src="https://ui-avatars.com/api/?name=User&background=random" class="rounded-circle me-1" width="25">
                            <span>Profil</span>
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>